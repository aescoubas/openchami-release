#!/usr/bin/make -f

%:
	dh $@

override_dh_auto_configure:
override_dh_auto_build:
override_dh_auto_test:

override_dh_auto_install:
	$(MAKE) install DESTDIR=$(CURDIR)/debian/openchami DEB_BUILD_ARCH=1

override_dh_installsystemd:
	dh_installsystemd --name=openchami-cert-renewal.timer --no-enable
	dh_installsystemd
